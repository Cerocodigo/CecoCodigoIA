Estructura de los campos en json de modelos
{
    "visible": true, -- true o false, Especifica si el campo es visible en el formulario
    "nombre": "MedioPago", Texto que represente el Nombre del campo, mismo nombre se utiliza en la Base de datos para la columna de datos que representa
    "etiqueta": "Medio de Pago", Texto visible de etqueta del campo en el formulario.
    "tipo_base": "SQL_TYPES", -- Tipo de campo a nivel de base de datos Mysql u otro
    "tipo_funcional": "Cecod_TYPES", -- son campos a nivel de funcional logico, cual sume cual resta, cual es el cliente y la relaciones entre ellos
    "requerido": true, -- determina si puede estar vacio
    "configuracion":{}, -- aqui segun el "tipo_funcional" se almacena la informacion necesaria para el funcionamiento del campo.
    "orden": 30, -- 0 a 100, determina el orden de los campos en el formulario y view inicial del modulo.
    "col": 6, -- 1 a 12, el ancho del div en el formulario col-md-xx
    "area": "main", -- main o side, determina la posicion en el formulario.
    "valor_default": "", -- [string, decimal o int]valor predeterminado en base de datos. null no pueder ser
    "placeholder": "", -- texto de ayuda a usaurio corto.
    "ayuda": "" -- Explicacion del campo y para que sirve al usuario.
}


